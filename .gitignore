/nbproject/private/
/nbproject/Makefile-*.mk
/nbproject/Package-*.bash
build.xml.data.CRC32

# 4. Archivos del Sistema Operativo
.DS_Store
Thumbs.db

# 5. Logs y archivos temporales
*.log
*.tmp